# Application Configuration
APP_NAME=AryaX Platform
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql+asyncpg://aryax:aryax_password@localhost:5432/aryax_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
REDIS_SESSION_TTL=86400

# Elasticsearch Configuration
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=aryax

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_DAYS=7

# API Configuration
API_KEY_PREFIX=sk_live

# Stripe Configuration
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# External APIs
OPENAI_API_KEY=
GEMINI_API_KEYS=

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1
ENCRYPTION_KEY=

# Admin
ADMIN_KEY=your-admin-key-here
ADMIN_PORTAL_PASSWORD=your-portal-password-here
HF_API_KEY=
